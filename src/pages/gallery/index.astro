---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const photos: CollectionEntry<"gallery">[] = await getCollection("gallery");
const sortedPhotos = photos.sort((a, b) => {
  const dateA = a.data.dateTaken?.valueOf() ?? 0;
  const dateB = b.data.dateTaken?.valueOf() ?? 0;
  return dateB - dateA;
});
---

<BaseLayout title="Photography Gallery">
  <main class="pt-32 pb-20 max-w-7xl mx-auto px-6">
    <header class="editorial-grid mb-24">
      <div class="col-span-12 lg:col-span-8">
        <p
          class="font-label text-xs tracking-widest uppercase text-outline dark:text-zinc-500 mb-4"
        >
          Gallery
        </p>
        <h1
          class="font-headline text-5xl md:text-7xl font-bold tracking-tighter text-on-surface dark:text-zinc-50 leading-none mb-8"
        >
          Visual <span class="text-outline-variant dark:text-zinc-600">Archives</span>.
        </h1>
        <p
          class="font-body text-lg text-on-surface-variant dark:text-zinc-400 max-w-xl leading-relaxed"
        >
          A curated collection of photographic explorations. Focusing on
          architectural details, light interplay, and the geometry of everyday
          spaces.
        </p>
      </div>
    </header>

    <div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6">
      {
        sortedPhotos.map((photo) => (
          <div class="break-inside-avoid relative overflow-hidden bg-surface-container-low dark:bg-zinc-900/50 border border-outline-variant/15 dark:border-zinc-800/50 group cursor-pointer">
            <img
              alt={photo.data.alt}
              class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105 opacity-90"
              src={
                photo.data.image ||
                "https://lh3.googleusercontent.com/aida-public/AB6AXuDa-texpMilhXHJ7zV8FeGoJESa0PNaNIbN2OdCPnssGyeB4GFJpe5V-C25YMsMuAGXMU27agahKHxCV7GJRQmrvPdl-2oFMp6PHWhX4P5lO1eBWbqR8oPfIalIME7ygNGcd8j7UFcn4Cz7Wu1SgyYquXR0BGp5PyOS5OxyVjjyJToKjQ__fnV0CG54FeVahxR7S7y508wJQOCvNl2TRYb_T4ErJcLBTvrkyzU7JSa9rkXxfiD78O7fOWoJSpO_Gf69KFRKEt_taKz_"
              }
            />
            <div class="absolute inset-0 bg-gradient-to-t from-surface/80 dark:from-zinc-950/90 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
              <span class="font-label text-[10px] tracking-widest uppercase text-outline dark:text-zinc-500 mb-2">
                {photo.data.category}
              </span>
              <h3 class="font-headline text-xl font-bold text-on-surface dark:text-zinc-100 leading-tight">
                {photo.data.title}
              </h3>
              {photo.data.location && (
                <span class="font-label text-xs text-on-surface-variant dark:text-zinc-400 flex items-center gap-1 mt-2">
                  <span class="material-symbols-outlined text-[14px]">
                    location_on
                  </span>
                  {photo.data.location}
                </span>
              )}
            </div>
          </div>
        ))
      }
      {
        sortedPhotos.length === 0 && (
          <div class="col-span-full py-24 text-center text-on-surface-variant font-body w-full">
            No images added to the gallery yet.
          </div>
        )
      }
    </div>
  </main>
</BaseLayout>
