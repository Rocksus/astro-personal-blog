---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const photos = await getCollection('gallery');
  return photos.map(photo => ({
    params: { slug: photo.id },
    props: { photo },
  }));
}

const { photo } = Astro.props;
---

<BaseLayout title={photo.data.title}>
    <main class="pt-32 pb-20 max-w-5xl mx-auto px-6">
        <a href="/gallery" class="font-label text-xs uppercase tracking-widest border-b border-outline-variant/30 dark:border-zinc-700 pb-1 hover:border-primary dark:hover:text-zinc-100 transition-all text-on-surface-variant dark:text-zinc-400 mb-12 inline-flex items-center gap-2">
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            Back to Gallery
        </a>

        <div class="mt-8 bg-surface-container-low dark:bg-zinc-900/50 border border-outline-variant/15 dark:border-zinc-800 p-4 md:p-8 flex flex-col md:flex-row gap-8 items-start">
            <div class="w-full md:w-2/3">
                <img src={photo.data.image} alt={photo.data.alt} class="w-full h-auto shadow-sm" />
            </div>
            <div class="w-full md:w-1/3 flex flex-col gap-6">
                <span class="font-label text-[10px] tracking-widest uppercase px-2 py-0.5 bg-surface-variant dark:bg-zinc-800 text-on-surface-variant dark:text-zinc-400 w-fit">
                    {photo.data.category}
                </span>

                <h1 class="font-headline text-3xl font-bold tracking-tight text-on-surface dark:text-zinc-50">
                    {photo.data.title}
                </h1>

                <div class="flex flex-col gap-3 border-t border-outline-variant/15 dark:border-zinc-800 pt-6 mt-4">
                    {photo.data.dateTaken && (
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-outline dark:text-zinc-500 text-[18px]">calendar_today</span>
                            <span class="font-body text-sm text-on-surface-variant dark:text-zinc-400">
                                {photo.data.dateTaken.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                            </span>
                        </div>
                    )}
                    {photo.data.location && (
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-outline dark:text-zinc-500 text-[18px]">location_on</span>
                            <span class="font-body text-sm text-on-surface-variant dark:text-zinc-400">
                                {photo.data.location}
                            </span>
                        </div>
                    )}
                </div>

                <p class="font-body text-on-surface-variant dark:text-zinc-400 text-sm leading-relaxed mt-4 italic border-l-2 border-outline-variant/30 dark:border-zinc-700 pl-4">
                    "{photo.data.alt}"
                </p>
            </div>
        </div>
    </main>
</BaseLayout>
