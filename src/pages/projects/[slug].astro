---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects: CollectionEntry<'projects'>[] = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<BaseLayout title={project.data.title}>
    <main class="pt-32 pb-20 max-w-4xl mx-auto px-6">
        <header class="mb-16">
            <a href="/projects" class="font-label text-xs uppercase tracking-widest border-b border-outline-variant/30 dark:border-zinc-700 pb-1 hover:border-primary transition-all text-on-surface-variant dark:text-zinc-400 mb-12 inline-flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
                Back to Archive
            </a>
            
            <div class="flex items-center gap-3 mb-6 mt-12">
                <span class="font-label text-[10px] tracking-widest uppercase px-2 py-0.5 bg-surface-variant dark:bg-zinc-800 text-on-surface-variant dark:text-zinc-400">Project</span>
                <span class="font-label text-[10px] tracking-widest uppercase text-outline dark:text-zinc-500">{project.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</span>
            </div>
            
            <h1 class="font-headline text-4xl md:text-6xl font-bold tracking-tight text-on-surface dark:text-zinc-50 mb-6">
                {project.data.title}
            </h1>
            
            <p class="font-body text-xl text-on-surface-variant dark:text-zinc-400 leading-relaxed max-w-2xl">
                {project.data.description}
            </p>
            
            <div class="flex flex-wrap gap-2 mt-8">
                {project.data.stack.map((tech: string) => (
                    <span class="font-label text-[10px] border border-outline-variant/30 dark:border-zinc-700 px-2 py-1 text-on-surface-variant dark:text-zinc-400">{tech}</span>
                ))}
            </div>
            
            {(project.data.repoUrl || project.data.liveUrl) && (
                <div class="flex gap-6 mt-8">
                    {project.data.liveUrl && (
                        <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="font-label text-xs uppercase tracking-widest font-bold text-on-surface dark:text-zinc-100 border-b-2 border-on-surface dark:border-zinc-100 pb-1 hover:text-primary dark:hover:text-zinc-300 transition-all inline-flex items-center gap-2">
                            Live Demo <span class="material-symbols-outlined text-[14px]">open_in_new</span>
                        </a>
                    )}
                    {project.data.repoUrl && (
                        <a href={project.data.repoUrl} target="_blank" rel="noopener noreferrer" class="font-label text-xs uppercase tracking-widest font-bold text-on-surface dark:text-zinc-100 border-b-2 border-outline-variant/30 dark:border-zinc-700 pb-1 hover:border-outline dark:hover:border-zinc-500 transition-all">
                            Repository
                        </a>
                    )}
                </div>
            )}
        </header>

        {project.data.thumbnail && (
            <div class="w-full aspect-[16/9] bg-surface-container-low dark:bg-zinc-900/50 mb-16 border border-outline-variant/15 dark:border-zinc-800 overflow-hidden">
                <img src={project.data.thumbnail} alt="Project Thumbnail" class="w-full h-full object-cover" />
            </div>
        )}

        <article class="prose prose-zinc dark:prose-invert max-w-none font-body text-on-surface-variant dark:text-zinc-400 prose-headings:font-headline prose-headings:text-on-surface dark:prose-headings:text-zinc-50 prose-a:text-on-surface dark:prose-a:text-zinc-100 prose-a:decoration-outline-variant/30 dark:prose-a:decoration-zinc-700 hover:prose-a:decoration-primary dark:hover:prose-a:decoration-zinc-300 prose-a:underline-offset-4 prose-code:font-headline prose-pre:bg-surface-variant dark:prose-pre:bg-zinc-900 prose-pre:border prose-pre:border-outline-variant/15 dark:prose-pre:border-zinc-800 prose-img:border prose-img:border-outline-variant/15 dark:prose-img:border-zinc-800">
            <Content />
        </article>
    </main>
</BaseLayout>
